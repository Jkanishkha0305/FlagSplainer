# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Lenses API Configuration (Required for MCP)
LENSES_API_HTTP_URL=http://your-lenses-host
LENSES_API_HTTP_PORT=8080
LENSES_API_WEBSOCKET_URL=ws://your-lenses-host
LENSES_API_WEBSOCKET_PORT=8080
LENSES_API_KEY=your-lenses-api-key-here

# Lenses Environment and Authentication
LENSES_ENVIRONMENT=dev
